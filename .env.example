# ECLM Agent — Variables d'environnement
# Copier en .env et remplir les valeurs

# Optionnel — seulement pour le bootstrap one-time (~10€)
ANTHROPIC_API_KEY=sk-ant-...

# Paths (les defaults sont relatifs au projet)
# ECLM_DATA_DIR=./data
# ECLM_MODELS_DIR=./models

# Docker
# ECLM_DOCKER_IMAGE=eclm-sandbox:latest

# Hyperparamètres (valeurs par défaut recommandées)
# ECLM_BEAM_WIDTH=5
# ECLM_MAX_RETRIES=3
# ECLM_CONFIDENCE_THRESHOLD=0.75
# ECLM_MIN_VERIFICATION_SCORE=0.8
